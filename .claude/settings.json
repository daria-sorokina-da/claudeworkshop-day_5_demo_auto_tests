{
  "permissions": {
    "allow": [
      "Write(**/CLAUDE.md)",
      "Write(README.md)",
      "Edit(**/CLAUDE.md)",
      "Edit(README.md)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/deny-app-writes.mjs",
            "shell": "bash"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/skills/update-docs/hook.mjs"
          }
        ]
      }
    ]
  }
}
