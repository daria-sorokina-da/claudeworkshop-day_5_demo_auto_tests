# Zephyr Squad Cloud API keys — from Jira → Apps → Zephyr Squad → API Keys.
# Copy this file to ".env" (same folder) and fill in. ".env" is gitignored.
ZEPHYR_ACCESS_KEY=
ZEPHYR_SECRET_KEY=
ZEPHYR_ACCOUNT_ID=

# Optional — only needed to resolve an issue KEY (e.g. QA-504) to its numeric
# issueId / projectId automatically. Skip these if you pass --issue-id/--project-id.
# JIRA_API_TOKEN is an Atlassian API token (id.atlassian.com → Security → API tokens).
JIRA_BASE_URL=https://anthonynolan.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
